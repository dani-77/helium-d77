// Personal status bar built on top of the Helium shell framework.
// `bar_width` is set from src/main.rs at startup, derived from the actual
// monitor width — no need to hand-edit it for a different screen.

// One workspace pill's worth of state. Populated from the compositor's
// actual live workspace list (Hyprland and Niri alike — both already come
// out of helium-wsl as the same Vec<Workspace>), so the bar shows exactly as
// many pills as exist instead of a hardcoded count.
export struct WorkspaceItem {
    id: int,
    label: string,
    active: bool,
    occupied: bool,
}

component Divider inherits Rectangle {
    width: 1px;
    height: 22px;
    border-width: 1px;
    border-color: #222;
}

component WorkspacePill inherits Rectangle {
    in property <string> label: "";
    in property <bool> active: false;
    in property <bool> occupied: false;
    callback clicked;

    width: 26px;
    height: 24px;
    background: active ? #76b900 : #1f1f1f;
    border-width: 1px;
    border-color: active ? #76b900 : #333;

    Text {
        text: label;
        color: active ? #0a0a0a : occupied ? #aaa : #555;
        font-size: 11px;
        font-family: "Space Mono";
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    Rectangle {
        visible: occupied && !active;
        width: 3px;
        height: 3px;
        border-radius: 1.5px;
        background: #76b900;
        x: (parent.width - self.width) / 2;
        y: parent.height - 6px;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component StatChip inherits Rectangle {
    in property <string> icon: "";
    in property <string> value: "";
    in property <bool> highlight: false;

    HorizontalLayout {
        alignment: center;
        spacing: 4px;

        Text {
            text: icon;
            color: highlight ? #76b900 : #666;
            font-size: 13px;
            font-family: "Symbols Nerd Font";
            vertical-alignment: center;
        }

        Text {
            text: value;
            color: highlight ? #d4d4d4 : #666;
            font-size: 12px;
            font-family: "Space Grotesk";
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

export component Bar inherits Window {
    in property <length> bar_width: 1346px;
    width: bar_width;
    height: 36px;
    background: transparent;

    in property <[WorkspaceItem]> workspaces: [];

    in property <string> net_text: "…";
    in property <bool> net_connected: false;
    in property <string> cpu_text: "…";
    in property <string> ram_text: "…";
    in property <string> bat_text: "…";
    in property <bool> bat_charging: false;
    in property <string> vol_text: "…";
    in property <bool> vol_muted: false;
    in property <string> clock_text: "";
    in property <string> weather_text: "…";

    callback workspace_clicked(int);
    callback launcher_clicked();
    callback session_clicked();
    callback network_clicked();
    callback volume_clicked();
    callback battery_clicked();

    Rectangle {
        background: #141414;
        border-radius: self.height / 2;
        clip: true;

        // --- Workspaces (pinned left) ---------------------------------------
        Rectangle {
            x: 0;
            width: 224px;
            height: 100%;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 6px;

                Rectangle {
                    width: 20px;

                    Text {
                        text: "\u{F009}";
                        color: #888;
                        font-size: 14px;
                        font-family: "Symbols Nerd Font";
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }

                    TouchArea { clicked => { launcher_clicked(); } }
                }

                for ws in workspaces : WorkspacePill {
                    label: ws.label;
                    active: ws.active;
                    occupied: ws.occupied;
                    clicked => { workspace_clicked(ws.id); }
                }
            }
        }

        // --- Weather + date/time — geometrically centered on the whole bar
        // as one unit, not on whatever space happens to be left between the
        // other two groups. ---
        Rectangle {
            x: (parent.width - self.width) / 2;
            width: 320px;
            height: 100%;

            HorizontalLayout {
                alignment: center;
                spacing: 10px;

                Text {
                    text: "\u{F0C2}";
                    color: #888;
                    font-size: 13px;
                    font-family: "Symbols Nerd Font";
                    vertical-alignment: center;
                }

                Text {
                    text: weather_text;
                    color: #888;
                    font-size: 12px;
                    font-family: "Space Grotesk";
                    vertical-alignment: center;
                }

                Divider { }

                Text {
                    text: "\u{F017}";
                    color: #76b900;
                    font-size: 13px;
                    font-family: "Symbols Nerd Font";
                    vertical-alignment: center;
                }

                Text {
                    text: clock_text;
                    color: #76b900;
                    font-size: 13px;
                    font-family: "Space Mono";
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
        }

        // --- Network / CPU / RAM / battery / volume / session (pinned right) --
        Rectangle {
            x: parent.width - self.width;
            width: 494px;
            height: 100%;

            HorizontalLayout {
                padding: 0;
                spacing: 0;

                StatChip {
                    width: 190px;
                    icon: "\u{F1EB}";
                    value: net_text;
                    highlight: net_connected;
                    TouchArea { clicked => { network_clicked(); } }
                }
                Divider { }
                StatChip { width: 64px; icon: "\u{F2DB}"; value: cpu_text; highlight: true; }
                Divider { }
                StatChip { width: 64px; icon: "\u{F0A0}"; value: ram_text; highlight: true; }
                Divider { }
                StatChip {
                    width: 64px;
                    icon: bat_charging ? "\u{F0E7}" : "\u{F240}";
                    value: bat_text;
                    highlight: true;
                    TouchArea { clicked => { battery_clicked(); } }
                }
                Divider { }
                StatChip {
                    width: 72px;
                    icon: vol_muted ? "\u{F026}" : "\u{F028}";
                    value: vol_text;
                    highlight: !vol_muted;
                    TouchArea { clicked => { volume_clicked(); } }
                }
                Divider { }

                Rectangle {
                    width: 40px;

                    Text {
                        text: "\u{F011}";
                        color: #888;
                        font-size: 14px;
                        font-family: "Symbols Nerd Font";
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }

                    TouchArea { clicked => { session_clicked(); } }
                }
            }
        }
    }
}
