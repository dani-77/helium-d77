# Template file for 'helium-d77'
pkgname=helium-d77
version=0.1.1
revision=1
build_style=cargo
hostmakedepends="pkg-config"
makedepends="wayland-devel libxkbcommon-devel fontconfig-devel freetype-devel pam-devel"
depends="pam-libs"
short_desc="Personal Wayland status bar built with the Helium shell framework"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://github.com/dani-77/helium-d77"
distfiles="https://github.com/dani-77/helium-d77/archive/refs/tags/${version}.tar.gz"
checksum=d08d581360aa071af34df82bf5e8b9e07db57be7040c7cbe6402a3727ff2bfb4

# build_style=cargo's default do_install only installs a single binary named
# ${pkgname}. This crate produces six -- mirrors the Makefile's BINS, which
# deliberately leaves out helium-locker (see the README's Locker section for
# the upstream niri/layer-shika incompatibility that keeps it out of
# `make install` too).
do_install() {
	vbin target/release/helium-shell
	vbin target/release/helium-launcher
	vbin target/release/helium-session
	vbin target/release/helium-osd
	vbin target/release/helium-wallpaper
	vbin target/release/helium-backdrop
	vlicense LICENSE
	vdoc README.md
}
